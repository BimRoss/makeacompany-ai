# Local / compose
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8080
BACKEND_INTERNAL_API_BASE_URL=http://localhost:8080
# Compose prod profile (frontend + in-compose kubectl port-forwards to admin cluster services)
KUBECONFIG_HOST_PATH=/Users/grant/.kube/config/admin.yaml
KUBECONFIG_CONTEXT=admin
PROD_BACKEND_PORT=18080
# Optional — LinkedIn Insight Tag partner id (enabled in production only)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

REDIS_URL=redis://localhost:6379/0
# Redis HASH listing Slack company channels (same key as employee-factory). Override only if your registry uses a non-default name.
# COMPANY_CHANNELS_REDIS_KEY=employee-factory:company_channels
# Optional write token for PUT /v1/admin/catalog (send as X-Admin-Token).
ADMIN_CATALOG_TOKEN=
# Optional read token for GET /v1/runtime/capability-catalog (send as Bearer token).
CAPABILITY_CATALOG_READ_TOKEN=
# Stripe-backed admin auth gate
ADMIN_ALLOWED_EMAIL=grant@bimross.com
ADMIN_SESSION_TTL_SEC=259200

# Stripe API — backend uses the first non-empty: STRIPE_SECRET_KEY, STRIPE_SECRET_KEY_LIVE,
# STRIPE_SECRET_KEY_TEST, STRIPE_API_KEY_TEST.
# STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...

# Optional — public keys for Stripe.js (mapped to NEXT_PUBLIC_* in docker compose)
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# Test-mode webhook signing secrets (Dashboard → Workbench event destinations). Same URL path; different whsec each.
STRIPE_WEBHOOK_SECRET_SNAPSHOT_TEST=whsec_...
STRIPE_WEBHOOK_SECRET_THIN_TEST=whsec_...
# Aliases (optional): STRIPE_WEBHOOK_SECRET_SNAPSHOT / STRIPE_WEBHOOK_SECRET_THIN / STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID_WAITLIST_TEST=price_...
STRIPE_PRICE_ID_WAITLIST_LIVE=price_...

# /employees Grafana embeds
HEALTH_GRAFANA_DASHBOARD_URL=
HEALTH_GRAFANA_PANEL_IDS=4,1,7
HEALTH_GRAFANA_PANEL_TITLES=Activities,Requests /min,Tool usage
HEALTH_GRAFANA_ADMIN_PANEL_IDS=1,2,3,4,5,6,7,8
HEALTH_GRAFANA_ADMIN_PANEL_TITLES=Request throughput,P95 latency,Error rate,Success vs error,Queue depth,Worker readiness,Tool mix,Webhook latency

# /twitter health stack (twitter + cookie health)
HEALTH_GRAFANA_TWITTER_DASHBOARD_URL=
HEALTH_GRAFANA_TWITTER_PANEL_IDS=1,3
HEALTH_GRAFANA_TWITTER_PANEL_TITLES=Indexer throughput,Worker throughput
HEALTH_PROMETHEUS_URL=
HEALTH_GRAFANA_URL=
HEALTH_TWITTER_INDEXER_URL=
HEALTH_TWITTER_WORKER_URLS=
HEALTH_COOKIE_STALE_AFTER_MINUTES=180
# Secret in runtime env/cluster (do not commit real value):
COOKIE_HEALTH_TOKEN=


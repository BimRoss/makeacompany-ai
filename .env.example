# Environment files (gitignored): `.env.dev` (local / test) and `.env.prod` (production cluster sync).
# Copy this file to both and fill in real values.
#
# Docker Compose loads secrets into containers from `${MAKEACOMPANY_AI_ENV_FILE:-.env.dev}` (override with
# `MAKEACOMPANY_AI_ENV_FILE=.env.prod` when you want prod keys in compose). Same ergonomics as slack-orchestrator's
# `SLACK_ORCHESTRATOR_ENV_FILE`.
#
# Host `go run` / `npm run dev` often read only `./.env`: run `./scripts/use-env.sh dev|prod` → symlink `.env` → `.env.dev|.env.prod`.
# Prod secrets: keep live keys only in `.env.prod`; run `./scripts/update-rancher-secrets.sh`
# (uses `.env.prod` when `ENV_FILE` is unset). Never use `.env.dev` for that script.

# Optional prod-like compose: `npm run docker:prod -- up --build` loads .env.prod for compose interpolation
# (KUBECONFIG_*) and frontend-prod defaults to .env.prod when MAKEACOMPANY_AI_ENV_FILE is unset.

# Local / compose
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Browser → makeacompany API. For `docker compose --profile local`, compose sets COMPOSE_PUBLIC_API_URL (default :8090).
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8090
# Optional — only needed for npm run dev on host without compose; in compose, docker-compose sets http://backend:8080
# BACKEND_INTERNAL_API_BASE_URL=http://localhost:8090
# Go backend: optional Bearer for /v1/internal/* snapshot refresh (Kubernetes CronJobs, compose one-shots).
# This is **not** Google OAuth — headless jobs cannot use a browser session. Human /v1/admin/* sign-in stays Google/magic-link only.
# If you leave this unset locally, POST /v1/internal/refresh-* still works when called with the **same** Authorization Bearer as
# `/admin` (your mac_admin_session token): the backend accepts either the service token or a valid admin session when the service token is empty.
# Production: set a random secret here and in cluster `makeacompany-ai-runtime-secrets` so CronJobs keep working without a logged-in human.
# Also paste into sibling employee-factory `.env.dev` when using optional compose snapshot warmers (see that repo’s .env.example).
# BACKEND_INTERNAL_SERVICE_TOKEN=
# Compose prod profile (frontend + in-compose kubectl port-forwards to admin cluster services)
# Optional — compose defaults to ${HOME}/.kube/config/admin.yaml when unset (matches BimRoss layout).
KUBECONFIG_HOST_PATH=/Users/grant/.kube/config/admin.yaml
KUBECONFIG_CONTEXT=admin
PROD_BACKEND_PORT=18080
# Optional — LinkedIn Insight Tag partner id (enabled in production only)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# Redis — host `go run` / tests: use the same host port as compose publishes (default 6380), matching sibling employee-factory
# `EMPLOYEE_FACTORY_REDIS_URL=redis://host.docker.internal:6380/0`. Docker backend service still uses in-network
# `redis://redis:6379/0` via compose `REDIS_URL: ${COMPOSE_REDIS_URL:-redis://redis:6379/0}` (see docker-compose.yml).
REDIS_URL=redis://localhost:6380/0
#
# Employee-factory keys (company channel registry, channel-knowledge digest, capability routing) live in the same Redis
# as everything else when COMPANY_CHANNELS_REDIS_URL is unset (recommended for local full stack with sibling employee-factory).
# Set COMPANY_CHANNELS_REDIS_URL only when the backend must read a *different* Redis than REDIS_URL (legacy split / prod edge cases).
# COMPANY_CHANNELS_REDIS_URL=redis://host.docker.internal:6379/0
# Kubernetes / other: COMPANY_CHANNELS_REDIS_URL=redis://employee-factory-redis.employee-factory.svc.cluster.local:6379/0
# Redis HASH listing Slack company channels (same key as employee-factory). Override only if your registry uses a non-default name.
# COMPANY_CHANNELS_REDIS_KEY=employee-factory:company_channels
# Redis LIST for Slack capability-router observability (LPUSH from employee-factory; /admin channel page).
# CAPABILITY_ROUTING_EVENTS_REDIS_KEY=employee-factory:capability_routing_events
# Optional write token for PUT /v1/admin/catalog (send as X-Admin-Token).
ADMIN_CATALOG_TOKEN=
# Optional read token for GET /v1/runtime/capability-catalog (send as Bearer token).
CAPABILITY_CATALOG_READ_TOKEN=
# When set: GET /v1/runtime/capability-catalog prefers this JSON; empty Redis is seeded from it; Redis reads merge
# in new skills from a cached fetch (see backend). Required if the catalog Redis key is absent unless you PUT /v1/admin/catalog.
# GET uses no auth; orchestrator should allow anonymous debug routes (default ORCHESTRATOR_DEBUG_ALLOW_ANON). Examples:
# SLACK_ORCHESTRATOR_CAPABILITY_CATALOG_URL=http://slack-orchestrator.slack-orchestrator.svc.cluster.local:8080/debug/capability-catalog
# SLACK_ORCHESTRATOR_CAPABILITY_CATALOG_URL=http://host.docker.internal:8080/debug/capability-catalog
# docker compose --profile local defaults the backend to host.docker.internal:${SLACK_ORCHESTRATOR_PORT:-8080}/debug/capability-catalog
# (same host/port idea as ORCHESTRATOR_DEBUG). Set empty in .env.dev only if you intentionally want no orchestrator catalog.
# SLACK_ORCHESTRATOR_CAPABILITY_CATALOG_URL=
# Admin sign-in allowlist is fixed in code (grant@bimross.com only). Tune session lifetime only:
ADMIN_SESSION_TTL_SEC=259200

# Stripe — one set per file (.env.dev = test, .env.prod = live).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_WAITLIST=price_...

# Company portal `/{channelId}/login` and `/admin/login` — Google OAuth (Next exchanges code; Go validates `id_token`).
# Authorized redirect URI in Google Cloud Console: `{APP_BASE_URL}/api/portal/auth/google/callback` (admin Google sign-in uses the same callback)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: HMAC secret for OAuth `state` (min 16 chars). If unset, `GOOGLE_OAUTH_CLIENT_SECRET` is used.
# PORTAL_GOOGLE_OAUTH_STATE_SECRET=

# Magic sign-in links (optional): Resend transactional email; `from` must be a verified sender/domain in Resend.
RESEND_API_KEY=
PORTAL_AUTH_EMAIL_FROM=

# Slack — same variable name as slack-orchestrator: copy SLACK_BOT_TOKEN from orchestrator’s `.env.dev` / `.env.prod`,
# or run `./scripts/sync-slack-bot-token-from-orchestrator.sh dev` / `... prod` (default: ../slack-orchestrator).
# Used for `/admin` Slack Users (Redis snapshot + Refresh pulls users.list and writes Redis); needs users:read + users:read.email.
# SLACK_BOT_TOKEN=xoxb-...
#
# Admin channel transcript (/admin/[channelId]): map Slack **bot user IDs** to employee headshots + names.
# Same keys as employee-factory `employee-factory-config` / `docs/slack-squad-ids.md` (not secrets — Slack user ids).
# Optional one-line form (employee slug → U…):
# MULTIAGENT_BOT_USER_IDS=ross:U0APX108QE7,tim:U0AQ10R2H8E,alex:U0APSMH05B5,garth:U0AQHT4B72M,joanne:U0AQL5WF8RK
# Per-bot overrides (win over the line above for that employee if set):
# ROSS_SLACK_BOT_ID=U0APX108QE7
# TIM_SLACK_BOT_ID=U0AQ10R2H8E
# ALEX_SLACK_BOT_ID=U0APSMH05B5
# GARTH_SLACK_BOT_ID=U0AQHT4B72M
# JOANNE_SLACK_BOT_ID=U0AQL5WF8RK

# Observability: `/admin` overview grid (8 panels on MakeACompany Observability dashboard).
# Optional origin-only URL when browsing localhost (avoids pasting full dashboard URL). Example: kubectl
# port-forward -n makeacompany-ai svc/makeacompany-ai-grafana 13000:3000 → set HEALTH_GRAFANA_LOCAL_BASE_URL=http://127.0.0.1:13000
# docker compose --profile prod sets this automatically to match PROD_GRAFANA_HOST_PORT (see docker-compose.yml).
HEALTH_GRAFANA_LOCAL_BASE_URL=
HEALTH_GRAFANA_DASHBOARD_URL=
HEALTH_GRAFANA_ADMIN_PANEL_IDS=1,2,3,4,9,10,11,8
HEALTH_GRAFANA_ADMIN_PANEL_TITLES=Requests /min,P95 latency,Inbound events by agent,Activities,JetStream publish /s,Worker orchestrator ingress,Orchestrator Socket Mode,Backend HTTP errors/min

# `/employees` team-card metrics: MakeACompany “agents” dashboard (`var-employee` = alex,tim,ross,garth,joanne).
HEALTH_GRAFANA_AGENTS_DASHBOARD_URL=
HEALTH_GRAFANA_AGENTS_PANEL_IDS=1,2
HEALTH_GRAFANA_AGENTS_PANEL_TITLES=Activities,All agents (goroutines)

# `/slack-orchestrator` service page
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_DASHBOARD_URL=
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_PANEL_IDS=1,2,3,4
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_PANEL_TITLES=Events API acks /s,JetStream publish /s,Publish latency p95,Socket Mode state

# `/twitter` Grafana embeds only (MakeACompany Twitter Health dashboard)
HEALTH_GRAFANA_TWITTER_DASHBOARD_URL=
HEALTH_GRAFANA_TWITTER_PANEL_IDS=1,3
HEALTH_GRAFANA_TWITTER_PANEL_TITLES=Indexer throughput,Worker throughput

# Health stack (indexer + cookie health)
HEALTH_PROMETHEUS_URL=
HEALTH_GRAFANA_URL=
HEALTH_TWITTER_INDEXER_URL=
HEALTH_TWITTER_WORKER_URLS=
HEALTH_COOKIE_STALE_AFTER_MINUTES=180
# Secret in runtime env/cluster (do not commit real value):
COOKIE_HEALTH_TOKEN=

# `/admin` orchestrator log — Next.js proxies GET /debug/decisions (+ channel-members for discover) to slack-orchestrator.
# **Companies strip channel list:** Next calls the Go backend GET /v1/admin/slack-member-channels (Redis snapshot
# `makeacompany:admin:slack_member_channels_snapshot`). The **Go backend** must have ORCHESTRATOR_DEBUG_* when running
# POST /v1/internal/refresh-slack-member-channels-snapshot (compose `slack-member-channels-snapshot-refresh`, hourly CronJob in rancher-admin).
# Optional override for the one-shot compose job only:
# MEMBER_CHANNELS_SNAPSHOT_REFRESH_URL=http://backend:8080/v1/internal/refresh-slack-member-channels-snapshot
#
# docker compose --profile prod: compose sets ORCHESTRATOR_DEBUG_BASE_URL=http://k8s-orchestrator-forward:8080
# (kubectl port-forward to prod svc/slack-orchestrator). Optional ORCHESTRATOR_DEBUG_TOKEN if you lock down the orchestrator with a bearer.
#
# docker compose --profile local: defaults to http://host.docker.internal:${SLACK_ORCHESTRATOR_PORT:-8080} so a slack-orchestrator
# container running in another terminal (published on that host port) is reachable. Match ORCHESTRATOR_PORT from slack-orchestrator/.env.
# SLACK_ORCHESTRATOR_PORT=8080
#
# Local npm run dev on host: port-forward or orchestrator on localhost, e.g.
#   kubectl port-forward -n slack-orchestrator svc/slack-orchestrator 18081:8080
# ORCHESTRATOR_DEBUG_BASE_URL=http://127.0.0.1:18081
# ORCHESTRATOR_DEBUG_TOKEN=
#
# One-shot: repopulate employee-factory:company_channels from Slack (orchestrator debug + backend discover).
# Requires ORCHESTRATOR_DEBUG_BASE_URL, BACKEND_API_BASE_URL (e.g. http://localhost:8090), and ADMIN_SESSION_TOKEN.
# BACKEND_API_BASE_URL=http://localhost:8090


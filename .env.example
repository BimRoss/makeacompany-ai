# Local / compose
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8080
BACKEND_INTERNAL_API_BASE_URL=http://localhost:8080
# Compose prod profile (frontend + in-compose kubectl port-forwards to admin cluster services)
KUBECONFIG_HOST_PATH=/Users/grant/.kube/config/admin.yaml
KUBECONFIG_CONTEXT=admin
PROD_BACKEND_PORT=18080
# Optional — LinkedIn Insight Tag partner id (enabled in production only)
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

REDIS_URL=redis://localhost:6379/0
# Optional: Redis instance that holds employee-factory:company_channels (defaults to REDIS_URL). In prod, point at employee-factory-redis if the registry is not replicated into makeacompany-ai-redis.
# COMPANY_CHANNELS_REDIS_URL=redis://employee-factory-redis.employee-factory.svc.cluster.local:6379/0
# Redis HASH listing Slack company channels (same key as employee-factory). Override only if your registry uses a non-default name.
# COMPANY_CHANNELS_REDIS_KEY=employee-factory:company_channels
# Redis LIST for Slack capability-router observability (LPUSH from employee-factory; /admin channel page).
# CAPABILITY_ROUTING_EVENTS_REDIS_KEY=employee-factory:capability_routing_events
# Optional write token for PUT /v1/admin/catalog (send as X-Admin-Token).
ADMIN_CATALOG_TOKEN=
# Optional read token for GET /v1/runtime/capability-catalog (send as Bearer token).
CAPABILITY_CATALOG_READ_TOKEN=
# Stripe-backed admin auth gate
ADMIN_ALLOWED_EMAIL=grant@bimross.com
ADMIN_SESSION_TTL_SEC=259200

# Stripe API — backend uses the first non-empty: STRIPE_SECRET_KEY, STRIPE_SECRET_KEY_LIVE,
# STRIPE_SECRET_KEY_TEST, STRIPE_API_KEY_TEST.
# STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...

# Optional — public keys for Stripe.js (mapped to NEXT_PUBLIC_* in docker compose)
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# Test-mode webhook signing secrets (Dashboard → Workbench event destinations). Same URL path; different whsec each.
STRIPE_WEBHOOK_SECRET_SNAPSHOT_TEST=whsec_...
STRIPE_WEBHOOK_SECRET_THIN_TEST=whsec_...
# Aliases (optional): STRIPE_WEBHOOK_SECRET_SNAPSHOT / STRIPE_WEBHOOK_SECRET_THIN / STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID_WAITLIST_TEST=price_...
STRIPE_PRICE_ID_WAITLIST_LIVE=price_...

# Observability: `/admin` overview grid (8 panels on MakeACompany Observability dashboard).
HEALTH_GRAFANA_DASHBOARD_URL=
HEALTH_GRAFANA_ADMIN_PANEL_IDS=1,2,3,4,9,10,11,8
HEALTH_GRAFANA_ADMIN_PANEL_TITLES=Requests /min,P95 latency,Inbound events by agent,Activities,JetStream publish /s,Worker orchestrator ingress,Orchestrator Socket Mode,Backend HTTP errors/min

# `/employees` team-card metrics: MakeACompany “agents” dashboard (`var-employee` = alex,tim,ross,garth,joanne).
HEALTH_GRAFANA_AGENTS_DASHBOARD_URL=
HEALTH_GRAFANA_AGENTS_PANEL_IDS=1,2,3,4
HEALTH_GRAFANA_AGENTS_PANEL_TITLES=Inbound Slack events /min,Outbound Slack posts /min,Orchestrator ingress (accepted) /s,Go goroutines (agent pod)

# `/slack-orchestrator` service page
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_DASHBOARD_URL=
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_PANEL_IDS=1,2,3,4
HEALTH_GRAFANA_SLACK_ORCHESTRATOR_PANEL_TITLES=Events API acks /s,JetStream publish /s,Publish latency p95,Socket Mode state

# `/twitter` Grafana embeds only (MakeACompany Twitter Health dashboard)
HEALTH_GRAFANA_TWITTER_DASHBOARD_URL=
HEALTH_GRAFANA_TWITTER_PANEL_IDS=1,3
HEALTH_GRAFANA_TWITTER_PANEL_TITLES=Indexer throughput,Worker throughput

# Health stack (indexer + cookie health)
HEALTH_PROMETHEUS_URL=
HEALTH_GRAFANA_URL=
HEALTH_TWITTER_INDEXER_URL=
HEALTH_TWITTER_WORKER_URLS=
HEALTH_COOKIE_STALE_AFTER_MINUTES=180
# Secret in runtime env/cluster (do not commit real value):
COOKIE_HEALTH_TOKEN=

# `/admin` orchestrator log table — Next.js proxies to slack-orchestrator GET /debug/decisions (no browser token).
#
# docker compose --profile prod: compose sets ORCHESTRATOR_DEBUG_BASE_URL=http://k8s-orchestrator-forward:8080
# (kubectl port-forward to prod svc/slack-orchestrator). Optional ORCHESTRATOR_DEBUG_TOKEN if you lock down the orchestrator with a bearer.
#
# Local npm run dev: port-forward then e.g.
#   kubectl port-forward -n slack-orchestrator svc/slack-orchestrator 18081:8080
# ORCHESTRATOR_DEBUG_BASE_URL=http://127.0.0.1:18081
# ORCHESTRATOR_DEBUG_TOKEN=

